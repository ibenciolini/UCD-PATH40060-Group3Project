library(mixOmics)
X <- prot_imputed
Y <- factor(samples$cancer_type_detailed)
samples_matched <- samples[match(rownames(X), samples$sample_id), ]
Y <- factor(samples_matched$cancer_type_detailed)
all(rownames(X) == samples_matched$sample_id)
plsda_res <- plsda(X, Y, ncomp = 5)
# Quick plot
plotIndiv(plsda_res,
comp = c(1, 2),
group = Y,
ind.names = FALSE,
ellipse = TRUE,
legend = TRUE,
title = "PLS-DA of QC-passed proteomics")
set.seed(42)
perf_res <- perf(plsda_res,
validation = "Mfold",
folds = 5,
nrepeat = 10,
progressBar = TRUE)
plot(perf_res, col = color.mixo(1:3))
plotLoadings(plsda_res,
comp = 1,
method = "mean",
contrib = "max",    # which class each protein is most associated with
ndisplay = 20)
plotLoadings(plsda_res,
comp = 2,
method = "mean",
contrib = "max",
ndisplay = 20)
set.seed(42)
tune_splsda <- tune.splsda(
X = prot_imputed,
Y = Y,
ncomp = 3,
test.keepX = c(5, 10, 15, 20, 25, 30, 50),
validation = "Mfold",
folds = 5,
nrepeat = 10,
dist = "centroids.dist",
progressBar = TRUE
)
tune_splsda$choice.keepX
plot(tune_splsda)
optimal_keepX <- tune_splsda$choice.keepX
splsda_res <- splsda(
X = prot_imputed,
Y = Y,
ncomp = 3,
keepX = optimal_keepX
)
plotIndiv(splsda_res,
comp = c(1, 2),
group = Y,
ind.names = FALSE,
ellipse = TRUE,
legend = TRUE,
title = "sPLS-DA of QC-passed proteomics")
plotLoadings(splsda_res,
comp = 1,
method = "mean",
contrib = "max",
ndisplay = 20)
library(randomForest)
rf_fit <- randomForest(x = prot_imputed,
y = Y,
ntree = 500,
importance = TRUE)
varImpPlot(rf_fit)
library(randomForestSRC)
colnames(prot_imputed) <- gsub("\\|", "_", colnames(prot_imputed))
sample_ann <- tibble(sample_id = names(cluster_labels),
cluster = paste0("C", cluster_labels)) |>
left_join(dplyr::select(samples, sample_id, os_months, os_event,
cancer_type_detailed),
by = "sample_id")
library(ConsensusClusterPlus)
BiocManager::install("ConsensusClusterPlus")
library(ConsensusClusterPlus)
results <- ConsensusClusterPlus(
t(prot_imputed),
maxK = 8,
reps = 100,
pItem = 0.8,
pFeature = 1,
clusterAlg = "km",
distance = "euclidean"
)
library(multiROC)
auroc(plsda_res)
library(umap)
umap_res <- umap(prot_imputed)
umap_df  <- as.data.frame(umap_res$layout) |>
mutate(subtype = Y,
cluster = sample_ann$cluster)
# Note: This cell is the slowest in the notebook.
# Set `cache = TRUE` in the chunk options after the first run to reduce run time.
# NMF consensus sweep across k
# Method "brunet": Lee & Seung multiplicative updates (standard for biology)
# .options = "v": verbose progress output
nmf_estimates <- nmf(
pca_scores_nn,
rank = K_MIN:K_MAX,
nrun = NMF_RUNS,
seed = 42,
method = "brunet",
.options = "v")
# Extract metrics
k_metrics <- nmf_estimates$measures |>
as_tibble() |>
rename(k = rank, silhouette = silhouette.consensus) |>
select(k, cophenetic, dispersion, silhouette, rss)
cat("Metrics across k:\n")
print(k_metrics)
# Plot all four metrics
k_metrics |>
pivot_longer(-k, names_to = "metric", values_to = "value") |>
ggplot(aes(x = k, y = value)) +
geom_line(colour = "#4E79A7", linewidth = 1) +
geom_point(size = 3, colour = "#4E79A7") +
facet_wrap(~ metric, scales = "free_y", ncol = 2) +
scale_x_continuous(breaks = K_MIN:K_MAX) +
labs(title = "NMF model selection across k",
subtitle = "Choose k where cophenetic and silhouette peak together",
x = "Number of clusters (k)", y = "Metric value") +
theme_bw(base_size = 12)
# Automatic selection: highest silhouette score
BEST_K <- k_metrics$k[which.max(k_metrics$silhouette)]
cat(sprintf("Selected k = %d  (silhouette = %.3f, cophenetic = %.3f)\n",
BEST_K,
k_metrics$silhouette[k_metrics$k == BEST_K],
k_metrics$cophenetic[k_metrics$k == BEST_K]))
# Manual override:
# To use the k from the published paper (k = 8) instead, uncomment:
BEST_K <- 5
nmf_best <- nmf(
t(pca_scores_nn), # transpose: features (PCs) as rows, samples as columns
rank = BEST_K,
nrun = NMF_RUNS,
seed = 42,
method = "brunet",
.options = "vr")
# Extract consensus matrix
cons_matrix <- consensus(nmf_best) # 218×218 expected
# Assign each sample to the cluster with its highest NMF basis weight.
# We use basis() rather than predict() here: predict() assigns to the
# component with the highest H-matrix value, which can collapse to a single
# cluster when one component dominates. basis() scores are per-sample and
# more reliably reflect the consensus structure.
basis_mat <- basis(nmf_best) # features × k (25 × BEST_K)
coef_mat  <- coef(nmf_best) # k × samples (BEST_K × 218)
# Cluster assignment: argmax across k for each sample (column of coef_mat)
cluster_labels <- apply(t(coef_mat), 1, which.max)
names(cluster_labels) <- colnames(coef_mat)  # real sample IDs are now column names
cat("cons_matrix dim:", dim(cons_matrix), "\n")  # should be 218 218
cat("Cluster distribution:\n")
print(table(cluster_labels))
# Fix: rename cons_matrix rows/cols to match real sample IDs
# pca_scores_nn rownames and cons_matrix rows are in the same order,
# so we can directly assign them
#rownames(cons_matrix) <- rownames(pca_scores_nn)
#colnames(cons_matrix) <- rownames(pca_scores_nn)
# NOTE: `basis_mat` used to be called `basis`, in case of downstream issues.
# Annotation data frame for the heatmap
sample_ann <- tibble(sample_id = names(cluster_labels),
cluster = paste0("C", cluster_labels)) |>
left_join(select(samples, sample_id, cancer_type_detailed), by = "sample_id") |>
column_to_rownames("sample_id")
# Colour palettes
cluster_colours <- setNames(
brewer.pal(max(BEST_K, 3), "Set2")[1:BEST_K],
paste0("C", 1:BEST_K))
subtypes_present <- unique(sample_ann$cancer_type_detailed)
subtype_colours <- setNames(
colorRampPalette(brewer.pal(8, "Set3"))(length(subtypes_present)),
subtypes_present)
# Sort by cluster using the cons_matrix row order
# to guarantee the annotation and matrix rows stay aligned
sample_order <- order(cluster_labels[rownames(cons_matrix)]) # match cons_matrix
cons_matrix_ordered <- cons_matrix[sample_order, sample_order]
# Build ordered annotation FIRST, keyed to the reordered matrix rows
ordered_sample_ids <- rownames(cons_matrix)[sample_order]
ann_ordered <- sample_ann[ordered_sample_ids, , drop = FALSE]
# Plot with ordered matrix
pheatmap(
cons_matrix_ordered, # use ordered matrix
cluster_rows = FALSE, cluster_cols = FALSE,
annotation_col = ann_ordered, # match annotation order
annotation_colors = list(cluster = cluster_colours, cancer_type_detailed = subtype_colours),
color = colorRampPalette(c("white", "#2171B5"))(100),
border_color = NA, show_rownames = FALSE, show_colnames = FALSE,
main = paste0("Consensus matrix, k = ", BEST_K),
fontsize = 10
)
k_metrics$k[which.max(k_metrics$dispersion)]
